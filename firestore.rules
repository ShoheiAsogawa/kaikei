rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthorizedUser() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          "hisahohoikuen@gmail.com"
        ];
    }

    function isLedgerShape() {
      return request.resource.data.keys().hasOnly(["payload", "updatedAt", "updatedBy"])
        && request.resource.data.updatedBy == request.auth.token.email
        && request.resource.data.payload is map
        && request.resource.data.payload.schemaVersion is int
        && request.resource.data.payload.entries is list
        && request.resource.data.payload.entries.size() <= 20000
        && request.resource.data.payload.budgets is list
        && request.resource.data.payload.budgets.size() <= 5000
        && request.resource.data.payload.fixedAssets is list
        && request.resource.data.payload.fixedAssets.size() <= 5000
        && request.resource.data.payload.accounts is list
        && request.resource.data.payload.accounts.size() <= 2000;
    }

    match /accounting_ledgers/senshu-hisaho-main {
      allow read: if isAuthorizedUser();
      allow create, update: if isAuthorizedUser() && isLedgerShape();
      allow delete: if false;
    }

    match /accounting_ledgers/{documentId} {
      allow read, write: if false;
    }
  }
}
